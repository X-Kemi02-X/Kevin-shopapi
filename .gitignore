# =========================================================
# DJANGO + PYTHON .gitignore
# =========================================================

# =========================================================
# PYTHON
# =========================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribución / empaquetado
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Instaladores
pip-log.txt
pip-delete-this-directory.txt

# =========================================================
# ENTORNOS VIRTUALES
# =========================================================
.venv/
venv/
env/
ENV/

# =========================================================
# VARIABLES DE ENTORNO
# =========================================================
.env
.env.*
!.env.example

# =========================================================
# DJANGO
# =========================================================
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Archivos generados
media/
staticfiles/
static_root/

# Secretos y certificados
*.pem
*.key
*.crt

# =========================================================
# MIGRACIONES (OPCIONAL)
# Descomenta si NO quieres subir migraciones
# =========================================================
# */migrations/*
# !*/migrations/__init__.py

# =========================================================
# CACHE / TESTS / COVERAGE
# =========================================================
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# =========================================================
# JUPYTER NOTEBOOK
# =========================================================
.ipynb_checkpoints/

# =========================================================
# TYPE CHECKERS / LINTERS
# =========================================================
.mypy_cache/
.dmypy.json
dmypy.json

.pyre/
.pytype/

.ruff_cache/

# =========================================================
# IDEs Y EDITORES
# =========================================================

# VS Code
.vscode/

# PyCharm / IntelliJ
.idea/
*.iml

# Sublime
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo

# =========================================================
# SISTEMA OPERATIVO
# =========================================================

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Linux
*~

# =========================================================
# ARCHIVOS TEMPORALES
# =========================================================
*.tmp
*.temp
*.bak
*.orig

# =========================================================
# NODE (si usas frontend con Django)
# =========================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================================================
# ARCHIVOS DE DEPLOY
# =========================================================
.heroku/
.vercel/
.netlify/

# =========================================================
# DOCKER
# =========================================================
docker-compose.override.yml

# =========================================================
# ARCHIVOS DE BASE DE DATOS
# =========================================================
*.sqlite3
*.db

# =========================================================
# LOGS
# =========================================================
logs/
*.log